{
  "name": "ebombo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@ebombo/web",
    "dev:api": "turbo dev --filter=@ebombo/api",
    "dev:admin": "turbo dev --filter=@ebombo/admin",
    "build:web": "turbo build --filter=@ebombo/web",
    "build:api": "turbo build --filter=@ebombo/api",
    "build:admin": "turbo build --filter=@ebombo/admin"
  },
  "devDependencies": {
    "critters": "^0.0.23",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "mysql2": "^3.19.0"
  }
}
